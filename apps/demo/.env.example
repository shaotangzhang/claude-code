###############################################################################
# Acme Demo · environment template                                            #
# Copy to .env and fill values. Most knobs have sensible defaults.            #
###############################################################################

APP_NAME=AcmeDemo
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000
APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# --- database ---------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=acme_demo
DB_USERNAME=root
DB_PASSWORD=

# --- session / cache / queue / mail -----------------------------------------
# Defaults to file-based so the demo boots without needing a `sessions` /
# `cache` table. Switch to `database` (and `php artisan session:table &&
# php artisan migrate`) for production.
SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_STORE=file
QUEUE_CONNECTION=sync
MAIL_MAILER=log
MAIL_FROM_ADDRESS=noreply@acme.test
MAIL_FROM_NAME="Acme"

###############################################################################
# Acme platform knobs                                                         #
###############################################################################

# admin / user-center / api prefixes
ACME_ADMIN_PREFIX=admin
ACME_API_PREFIX=api
ACME_API_VERSION=v1
ACME_USER_CENTER_PREFIX=account

# cms
ACME_CMS_FORCE_THEME=
ACME_CMS_PAGE_TTL=0
ACME_CMS_BLOCK_TTL=0
ACME_CMS_MOUNT_CATCH_ALL=true

# blog
ACME_BLOG_PREFIX=blog
ACME_BLOG_RSS_TTL=600
ACME_BLOG_SITE_TITLE="Acme Blog"

# catalog
ACME_CATALOG_PREFIX=catalog
ACME_CATALOG_CURRENCY=USD
ACME_CATALOG_CURRENCY_SYMBOL=$

# cart
ACME_CART_PREFIX=cart
ACME_CART_TAX_BPS=0
ACME_CART_TAX_LABEL=Tax
ACME_CART_SHIPPING_CENTS=599
ACME_CART_FREE_SHIP_AT=10000
ACME_CART_SHIPPING_LABEL="Standard shipping"
ACME_CART_BUILTIN_SHIPPING=true

# membership
ACME_MEMBERSHIP_PREFIX=membership
ACME_MEMBERSHIP_GRACE_DAYS=7
ACME_MEMBERSHIP_AUTO_RENEW=false

# abandoned-cart
ACME_CART_ABANDON_HOURS=24
ACME_CART_ABANDON_TTL=72
ACME_CART_ABANDON_BATCH=200

# search
ACME_SEARCH_DRIVER=database
ACME_SEARCH_PREFIX=search
MEILI_HOST=http://127.0.0.1:7700
MEILI_API_KEY=
MEILI_INDEX_PREFIX=acme_products
ELASTIC_HOST=http://127.0.0.1:9200
ELASTIC_API_KEY=
ELASTIC_USERNAME=
ELASTIC_PASSWORD=

# payments
ACME_PAYMENTS_PREFIX=payments
ACME_PAYMENTS_DEFAULT=manual

# payments-stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=${APP_URL}/orders
STRIPE_CANCEL_URL=${APP_URL}/cart

# payments-stripe-subscriptions
STRIPE_SUBS_WEBHOOK_SECRET=
STRIPE_SUBS_SUCCESS_URL=${APP_URL}/account/membership
STRIPE_SUBS_CANCEL_URL=${APP_URL}/membership/plans

# payments-paypal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
PAYPAL_WEBHOOK_ID=
PAYPAL_RETURN_URL=${APP_URL}/orders
PAYPAL_CANCEL_URL=${APP_URL}/cart

# payments-alipay
ALIPAY_APP_ID=
ALIPAY_APP_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_MODE=sandbox
ALIPAY_RETURN_URL=${APP_URL}/orders
ALIPAY_NOTIFY_URL=${APP_URL}/payments/alipay/webhook

# payments-wechatpay
WECHATPAY_MCH_ID=
WECHATPAY_APP_ID=
WECHATPAY_SERIAL_NO=
WECHATPAY_PRIVATE_KEY=
WECHATPAY_APIV3_KEY=
WECHATPAY_PLATFORM_PUBLIC_KEY=
WECHATPAY_TRADE_TYPE=native
WECHATPAY_NOTIFY_URL=${APP_URL}/payments/wechatpay/webhook

# notifications
ACME_NOTIFY_MAIL_FROM=noreply@acme.test
ACME_NOTIFY_OPS_EMAIL=ops@acme.test

# notifications-sms (Twilio-compatible)
ACME_SMS_API_BASE=https://api.twilio.com/2010-04-01
ACME_SMS_SID=
ACME_SMS_TOKEN=
ACME_SMS_FROM=

# notifications-webhook
ACME_WEBHOOK_URL=
ACME_WEBHOOK_SECRET=
