APP_NAME=AcmeDemo
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=acme_demo
DB_USERNAME=root
DB_PASSWORD=

CACHE_STORE=database
SESSION_DRIVER=database
QUEUE_CONNECTION=sync

MAIL_MAILER=log

# Acme platform knobs
ACME_ADMIN_PREFIX=admin
ACME_CART_PREFIX=cart
ACME_CART_BUILTIN_SHIPPING=true
ACME_CART_TAX_BPS=0

# Membership
ACME_MEMBERSHIP_GRACE_DAYS=7

# Catalog default currency
ACME_CATALOG_CURRENCY=USD
ACME_CATALOG_CURRENCY_SYMBOL=$

# Payment gateways — leave blank to keep Manual as the only working one
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=${APP_URL}/orders
STRIPE_CANCEL_URL=${APP_URL}/cart

PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
PAYPAL_WEBHOOK_ID=
PAYPAL_RETURN_URL=${APP_URL}/orders
PAYPAL_CANCEL_URL=${APP_URL}/cart

# Notifications
ACME_NOTIFY_MAIL_FROM=noreply@acme.test
ACME_NOTIFY_OPS_EMAIL=ops@acme.test
