{
    "name": "acme/demo",
    "description": "Dogfood demo host. Installs the full acme/* stack and seeds a tiny end-to-end commerce scenario.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "laravel/framework": "^12.0",
        "acme/contracts": "*",
        "acme/support": "*",
        "acme/starter": "*",
        "acme/auth": "*",
        "acme/rbac": "*",
        "acme/admin": "*",
        "acme/user-center": "*",
        "acme/cms-core": "*",
        "acme/cms-admin": "*",
        "acme/media": "*",
        "acme/i18n": "*",
        "acme/seo": "*",
        "acme/blog": "*",
        "acme/catalog": "*",
        "acme/membership": "*",
        "acme/cart": "*",
        "acme/payments": "*",
        "acme/checkout": "*",
        "acme/commerce": "*",
        "acme/wishlist": "*",
        "acme/search": "*",
        "acme/notifications": "*",
        "acme/loyalty-redemption": "*",
        "acme/multi-currency-pricing": "*",
        "acme/shipping-zones": "*",
        "acme/shipping-weight": "*",
        "acme/payments-stripe": "*",
        "acme/payments-paypal": "*"
    },
    "repositories": [
        { "type": "path", "url": "../../packages/*", "options": { "symlink": true } }
    ],
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "scripts": {
        "smoke": "php artisan acme:modules"
    },
    "config": {
        "sort-packages": true
    }
}
