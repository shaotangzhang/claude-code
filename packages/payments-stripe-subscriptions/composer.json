{
    "name": "acme/payments-stripe-subscriptions",
    "description": "Bridge acme/membership subscriptions to Stripe Subscriptions. Stripe handles recurring billing; this package translates Stripe webhook events to membership.PaymentReceived.",
    "type": "library",
    "license": "MIT",
    "version": "0.1.0",
    "repositories": [
        { "type": "path", "url": "../contracts",       "options": { "symlink": true } },
        { "type": "path", "url": "../support",         "options": { "symlink": true } },
        { "type": "path", "url": "../starter",         "options": { "symlink": true } },
        { "type": "path", "url": "../auth",            "options": { "symlink": true } },
        { "type": "path", "url": "../rbac",            "options": { "symlink": true } },
        { "type": "path", "url": "../media",           "options": { "symlink": true } },
        { "type": "path", "url": "../cms-core",        "options": { "symlink": true } },
        { "type": "path", "url": "../catalog",         "options": { "symlink": true } },
        { "type": "path", "url": "../cart",            "options": { "symlink": true } },
        { "type": "path", "url": "../membership",      "options": { "symlink": true } },
        { "type": "path", "url": "../payments",        "options": { "symlink": true } },
        { "type": "path", "url": "../checkout",        "options": { "symlink": true } },
        { "type": "path", "url": "../commerce",        "options": { "symlink": true } },
        { "type": "path", "url": "../payments-stripe", "options": { "symlink": true } }
    ],
    "require": {
        "php": "^8.3",
        "ext-openssl": "*",
        "acme/starter": "*",
        "acme/membership": "*",
        "acme/payments-stripe": "*",
        "illuminate/database": "^12.0",
        "illuminate/events": "^12.0",
        "illuminate/http": "^12.0",
        "illuminate/routing": "^12.0",
        "illuminate/support": "^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": { "psr-4": { "Acme\\PaymentsStripeSubscriptions\\": "src/" } },
    "autoload-dev": { "psr-4": { "Acme\\PaymentsStripeSubscriptions\\Tests\\": "tests/" } },
    "extra": {
        "laravel": { "providers": ["Acme\\PaymentsStripeSubscriptions\\StripeSubscriptionsServiceProvider"] },
        "acme": {
            "module": {
                "key": "payments-stripe-subscriptions",
                "title": "Acme Payments · Stripe Subscriptions",
                "version": "0.1.0",
                "layer": 3,
                "depends": ["membership", "payments-stripe"]
            }
        }
    }
}
