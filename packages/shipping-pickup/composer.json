{
    "name": "acme/shipping-pickup",
    "description": "In-store / warehouse pickup. Each location is a free 'pickup' option at checkout.",
    "type": "library",
    "license": "MIT",
    "version": "0.1.0",
    "repositories": [
        { "type": "path", "url": "../contracts", "options": { "symlink": true } },
        { "type": "path", "url": "../support",   "options": { "symlink": true } },
        { "type": "path", "url": "../starter",   "options": { "symlink": true } },
        { "type": "path", "url": "../auth",      "options": { "symlink": true } },
        { "type": "path", "url": "../rbac",      "options": { "symlink": true } },
        { "type": "path", "url": "../media",     "options": { "symlink": true } },
        { "type": "path", "url": "../cms-core",  "options": { "symlink": true } },
        { "type": "path", "url": "../catalog",   "options": { "symlink": true } },
        { "type": "path", "url": "../cart",      "options": { "symlink": true } }
    ],
    "require": {
        "php": "^8.3",
        "acme/starter": "*",
        "acme/cart": "*",
        "illuminate/database": "^12.0",
        "illuminate/support": "^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": { "psr-4": { "Acme\\ShippingPickup\\": "src/" } },
    "autoload-dev": { "psr-4": { "Acme\\ShippingPickup\\Tests\\": "tests/" } },
    "extra": {
        "laravel": { "providers": ["Acme\\ShippingPickup\\ShippingPickupServiceProvider"] },
        "acme": {
            "module": {
                "key": "shipping-pickup",
                "title": "Acme Shipping · Pickup",
                "version": "0.1.0",
                "layer": 3,
                "depends": ["cart"]
            }
        }
    }
}
