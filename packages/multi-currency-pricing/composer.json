{
    "name": "acme/multi-currency-pricing",
    "description": "Per-currency price book for SKUs. Replaces cart's DefaultPriceResolver with a table-driven lookup.",
    "type": "library",
    "license": "MIT",
    "version": "0.1.0",
    "repositories": [
        { "type": "path", "url": "../contracts", "options": { "symlink": true } },
        { "type": "path", "url": "../support",   "options": { "symlink": true } },
        { "type": "path", "url": "../starter",   "options": { "symlink": true } },
        { "type": "path", "url": "../auth",      "options": { "symlink": true } },
        { "type": "path", "url": "../rbac",      "options": { "symlink": true } },
        { "type": "path", "url": "../media",     "options": { "symlink": true } },
        { "type": "path", "url": "../cms-core",  "options": { "symlink": true } },
        { "type": "path", "url": "../catalog",   "options": { "symlink": true } },
        { "type": "path", "url": "../cart",      "options": { "symlink": true } }
    ],
    "require": {
        "php": "^8.3",
        "acme/starter": "*",
        "acme/cart": "*",
        "acme/catalog": "*",
        "illuminate/database": "^12.0",
        "illuminate/support": "^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Acme\\MultiCurrencyPricing\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Acme\\MultiCurrencyPricing\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": ["Acme\\MultiCurrencyPricing\\MultiCurrencyPricingServiceProvider"]
        },
        "acme": {
            "module": {
                "key": "multi-currency-pricing",
                "title": "Acme Multi-currency pricing",
                "version": "0.1.0",
                "layer": 3,
                "depends": ["cart", "catalog"]
            }
        }
    }
}
