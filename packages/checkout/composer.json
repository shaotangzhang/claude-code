{
    "name": "acme/checkout",
    "description": "Order placement: address + shipping + payment, Order state machine, payment listener bridge.",
    "type": "library",
    "license": "MIT",
    "version": "0.1.0",
    "repositories": [
        { "type": "path", "url": "../contracts",   "options": { "symlink": true } },
        { "type": "path", "url": "../support",     "options": { "symlink": true } },
        { "type": "path", "url": "../starter",     "options": { "symlink": true } },
        { "type": "path", "url": "../auth",        "options": { "symlink": true } },
        { "type": "path", "url": "../rbac",        "options": { "symlink": true } },
        { "type": "path", "url": "../media",       "options": { "symlink": true } },
        { "type": "path", "url": "../cms-core",    "options": { "symlink": true } },
        { "type": "path", "url": "../catalog",     "options": { "symlink": true } },
        { "type": "path", "url": "../cart",        "options": { "symlink": true } },
        { "type": "path", "url": "../membership",  "options": { "symlink": true } },
        { "type": "path", "url": "../payments",    "options": { "symlink": true } }
    ],
    "require": {
        "php": "^8.3",
        "acme/starter": "*",
        "acme/auth": "*",
        "acme/rbac": "*",
        "acme/cms-core": "*",
        "acme/catalog": "*",
        "acme/cart": "*",
        "acme/membership": "*",
        "acme/payments": "*",
        "illuminate/database": "^12.0",
        "illuminate/events": "^12.0",
        "illuminate/http": "^12.0",
        "illuminate/routing": "^12.0",
        "illuminate/support": "^12.0",
        "illuminate/view": "^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Acme\\Checkout\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Acme\\Checkout\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": ["Acme\\Checkout\\CheckoutServiceProvider"]
        },
        "acme": {
            "module": {
                "key": "checkout",
                "title": "Acme Checkout",
                "version": "0.1.0",
                "layer": 3,
                "depends": ["cart", "membership", "payments"]
            }
        }
    }
}
