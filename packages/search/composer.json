{
    "name": "acme/search",
    "description": "Catalog search with facets. Pluggable driver (default: database LIKE); first-class hook for MeiliSearch / Elasticsearch replacement.",
    "type": "library",
    "license": "MIT",
    "version": "0.1.0",
    "repositories": [
        { "type": "path", "url": "../contracts", "options": { "symlink": true } },
        { "type": "path", "url": "../support",   "options": { "symlink": true } },
        { "type": "path", "url": "../starter",   "options": { "symlink": true } },
        { "type": "path", "url": "../auth",      "options": { "symlink": true } },
        { "type": "path", "url": "../rbac",      "options": { "symlink": true } },
        { "type": "path", "url": "../media",     "options": { "symlink": true } },
        { "type": "path", "url": "../cms-core",  "options": { "symlink": true } },
        { "type": "path", "url": "../catalog",   "options": { "symlink": true } }
    ],
    "require": {
        "php": "^8.3",
        "acme/starter": "*",
        "acme/cms-core": "*",
        "acme/catalog": "*",
        "illuminate/console": "^12.0",
        "illuminate/database": "^12.0",
        "illuminate/events": "^12.0",
        "illuminate/http": "^12.0",
        "illuminate/routing": "^12.0",
        "illuminate/support": "^12.0",
        "illuminate/view": "^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Acme\\Search\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Acme\\Search\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": ["Acme\\Search\\SearchServiceProvider"]
        },
        "acme": {
            "module": {
                "key": "search",
                "title": "Acme Search",
                "version": "0.1.0",
                "layer": 3,
                "depends": ["catalog"]
            }
        }
    }
}
