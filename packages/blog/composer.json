{
    "name": "acme/blog",
    "description": "Blog: articles, categories, tags, comments, RSS, subscriptions. Integrates with cms-core via Block types.",
    "type": "library",
    "license": "MIT",
    "version": "0.1.0",
    "repositories": [
        { "type": "path", "url": "../contracts", "options": { "symlink": true } },
        { "type": "path", "url": "../support",   "options": { "symlink": true } },
        { "type": "path", "url": "../starter",   "options": { "symlink": true } },
        { "type": "path", "url": "../auth",      "options": { "symlink": true } },
        { "type": "path", "url": "../rbac",      "options": { "symlink": true } },
        { "type": "path", "url": "../cms-core",  "options": { "symlink": true } }
    ],
    "require": {
        "php": "^8.3",
        "acme/starter": "*",
        "acme/auth": "*",
        "acme/rbac": "*",
        "acme/cms-core": "*",
        "illuminate/database": "^12.0",
        "illuminate/events": "^12.0",
        "illuminate/routing": "^12.0",
        "illuminate/support": "^12.0",
        "illuminate/view": "^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Acme\\Blog\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Acme\\Blog\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": ["Acme\\Blog\\BlogServiceProvider"]
        },
        "acme": {
            "module": {
                "key": "blog",
                "title": "Acme Blog",
                "version": "0.1.0",
                "layer": 3,
                "depends": ["cms-core"]
            }
        }
    }
}
