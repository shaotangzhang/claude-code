{
    "name": "acme/seo",
    "description": "Sitemap, robots, canonical, OG/Twitter card metadata for CMS-rendered pages.",
    "type": "library",
    "license": "MIT",
    "version": "0.1.0",
    "repositories": [
        { "type": "path", "url": "../contracts", "options": { "symlink": true } },
        { "type": "path", "url": "../support",   "options": { "symlink": true } },
        { "type": "path", "url": "../starter",   "options": { "symlink": true } },
        { "type": "path", "url": "../auth",      "options": { "symlink": true } },
        { "type": "path", "url": "../rbac",      "options": { "symlink": true } },
        { "type": "path", "url": "../cms-core",  "options": { "symlink": true } }
    ],
    "require": {
        "php": "^8.3",
        "acme/starter": "*",
        "acme/cms-core": "*",
        "illuminate/database": "^12.0",
        "illuminate/routing": "^12.0",
        "illuminate/support": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "Acme\\Seo\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": ["Acme\\Seo\\SeoServiceProvider"]
        },
        "acme": {
            "module": {
                "key": "seo",
                "title": "Acme SEO",
                "version": "0.1.0",
                "layer": 2,
                "depends": ["cms-core"]
            }
        }
    }
}
