{
    "name": "acme/membership",
    "description": "Tiers, plans, subscriptions, billing-cycle state machine. Payment-gateway agnostic — emits PaymentDue events.",
    "type": "library",
    "license": "MIT",
    "version": "0.1.0",
    "repositories": [
        { "type": "path", "url": "../contracts", "options": { "symlink": true } },
        { "type": "path", "url": "../support",   "options": { "symlink": true } },
        { "type": "path", "url": "../starter",   "options": { "symlink": true } },
        { "type": "path", "url": "../auth",      "options": { "symlink": true } },
        { "type": "path", "url": "../rbac",      "options": { "symlink": true } },
        { "type": "path", "url": "../cms-core",  "options": { "symlink": true } }
    ],
    "require": {
        "php": "^8.3",
        "acme/starter": "*",
        "acme/auth": "*",
        "acme/rbac": "*",
        "acme/cms-core": "*",
        "illuminate/console": "^12.0",
        "illuminate/database": "^12.0",
        "illuminate/events": "^12.0",
        "illuminate/routing": "^12.0",
        "illuminate/support": "^12.0",
        "illuminate/view": "^12.0",
        "nesbot/carbon": "^3.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Acme\\Membership\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Acme\\Membership\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": ["Acme\\Membership\\MembershipServiceProvider"]
        },
        "acme": {
            "module": {
                "key": "membership",
                "title": "Acme Membership",
                "version": "0.1.0",
                "layer": 3,
                "depends": ["rbac"]
            }
        }
    }
}
