{
    "name": "acme/auth",
    "description": "User identity, authentication, registration, password reset, 2FA & SSO scaffolding.",
    "type": "library",
    "license": "MIT",
    "version": "0.1.0",
    "repositories": [
        { "type": "path", "url": "../contracts", "options": { "symlink": true } },
        { "type": "path", "url": "../support",   "options": { "symlink": true } },
        { "type": "path", "url": "../starter",   "options": { "symlink": true } }
    ],
    "require": {
        "php": "^8.3",
        "acme/contracts": "*",
        "acme/support": "*",
        "acme/starter": "*",
        "illuminate/auth": "^12.0",
        "illuminate/database": "^12.0",
        "illuminate/support": "^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Acme\\Auth\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Acme\\Auth\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Acme\\Auth\\AuthServiceProvider"
            ]
        },
        "acme": {
            "module": {
                "key": "auth",
                "title": "Acme Auth",
                "version": "0.1.0",
                "layer": 1,
                "depends": ["starter"]
            }
        }
    }
}
