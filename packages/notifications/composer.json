{
    "name": "acme/notifications",
    "description": "Listener-based notification dispatcher with channel abstraction. Default channels: mail, log; SMS / webhook live in sub-packages.",
    "type": "library",
    "license": "MIT",
    "version": "0.1.0",
    "repositories": [
        { "type": "path", "url": "../contracts", "options": { "symlink": true } },
        { "type": "path", "url": "../support",   "options": { "symlink": true } },
        { "type": "path", "url": "../starter",   "options": { "symlink": true } },
        { "type": "path", "url": "../auth",      "options": { "symlink": true } },
        { "type": "path", "url": "../rbac",      "options": { "symlink": true } },
        { "type": "path", "url": "../media",     "options": { "symlink": true } },
        { "type": "path", "url": "../cms-core",  "options": { "symlink": true } },
        { "type": "path", "url": "../catalog",   "options": { "symlink": true } },
        { "type": "path", "url": "../cart",      "options": { "symlink": true } },
        { "type": "path", "url": "../membership","options": { "symlink": true } },
        { "type": "path", "url": "../payments",  "options": { "symlink": true } },
        { "type": "path", "url": "../checkout",  "options": { "symlink": true } },
        { "type": "path", "url": "../commerce",  "options": { "symlink": true } },
        { "type": "path", "url": "../blog",      "options": { "symlink": true } }
    ],
    "require": {
        "php": "^8.3",
        "acme/starter": "*",
        "acme/auth": "*",
        "acme/checkout": "*",
        "acme/commerce": "*",
        "acme/blog": "*",
        "illuminate/database": "^12.0",
        "illuminate/events": "^12.0",
        "illuminate/mail": "^12.0",
        "illuminate/support": "^12.0",
        "illuminate/view": "^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Acme\\Notifications\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Acme\\Notifications\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": ["Acme\\Notifications\\NotificationsServiceProvider"]
        },
        "acme": {
            "module": {
                "key": "notifications",
                "title": "Acme Notifications",
                "version": "0.1.0",
                "layer": 3,
                "depends": ["checkout", "commerce", "blog"]
            }
        }
    }
}
