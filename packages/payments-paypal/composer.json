{
    "name": "acme/payments-paypal",
    "description": "PayPal gateway implementation for acme/payments. Uses PayPal Orders v2 REST API.",
    "type": "library",
    "license": "MIT",
    "version": "0.1.0",
    "repositories": [
        { "type": "path", "url": "../contracts",  "options": { "symlink": true } },
        { "type": "path", "url": "../support",    "options": { "symlink": true } },
        { "type": "path", "url": "../starter",    "options": { "symlink": true } },
        { "type": "path", "url": "../auth",       "options": { "symlink": true } },
        { "type": "path", "url": "../rbac",       "options": { "symlink": true } },
        { "type": "path", "url": "../payments",   "options": { "symlink": true } }
    ],
    "require": {
        "php": "^8.3",
        "acme/starter": "*",
        "acme/payments": "*",
        "illuminate/cache": "^12.0",
        "illuminate/http": "^12.0",
        "illuminate/support": "^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Acme\\PaymentsPayPal\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Acme\\PaymentsPayPal\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": ["Acme\\PaymentsPayPal\\PayPalServiceProvider"]
        },
        "acme": {
            "module": {
                "key": "payments-paypal",
                "title": "Acme Payments · PayPal",
                "version": "0.1.0",
                "layer": 3,
                "depends": ["payments"]
            }
        }
    }
}
