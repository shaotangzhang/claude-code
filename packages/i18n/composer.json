{
    "name": "acme/i18n",
    "description": "Content translations with fallback. Polymorphic translation table; complementary to JSON-column HasTranslations.",
    "type": "library",
    "license": "MIT",
    "version": "0.1.0",
    "repositories": [
        { "type": "path", "url": "../contracts", "options": { "symlink": true } },
        { "type": "path", "url": "../support",   "options": { "symlink": true } },
        { "type": "path", "url": "../starter",   "options": { "symlink": true } }
    ],
    "require": {
        "php": "^8.3",
        "acme/starter": "*",
        "illuminate/database": "^12.0",
        "illuminate/support": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "Acme\\I18n\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": ["Acme\\I18n\\I18nServiceProvider"]
        },
        "acme": {
            "module": {
                "key": "i18n",
                "title": "Acme i18n",
                "version": "0.1.0",
                "layer": 2,
                "depends": ["starter"]
            }
        }
    }
}
