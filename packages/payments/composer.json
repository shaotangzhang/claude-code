{
    "name": "acme/payments",
    "description": "Payment-gateway abstraction + ledger + webhook plumbing. Ships a Manual gateway by default; bind your own PaymentGateway impl for real providers.",
    "type": "library",
    "license": "MIT",
    "version": "0.2.0",
    "repositories": [
        { "type": "path", "url": "../contracts", "options": { "symlink": true } },
        { "type": "path", "url": "../support",   "options": { "symlink": true } },
        { "type": "path", "url": "../starter",   "options": { "symlink": true } },
        { "type": "path", "url": "../auth",      "options": { "symlink": true } },
        { "type": "path", "url": "../rbac",      "options": { "symlink": true } }
    ],
    "require": {
        "php": "^8.3",
        "acme/starter": "*",
        "acme/auth": "*",
        "acme/rbac": "*",
        "illuminate/database": "^12.0",
        "illuminate/events": "^12.0",
        "illuminate/http": "^12.0",
        "illuminate/routing": "^12.0",
        "illuminate/support": "^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Acme\\Payments\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Acme\\Payments\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": ["Acme\\Payments\\PaymentsServiceProvider"]
        },
        "acme": {
            "module": {
                "key": "payments",
                "title": "Acme Payments",
                "version": "0.1.0",
                "layer": 3,
                "depends": ["rbac"]
            }
        }
    }
}
