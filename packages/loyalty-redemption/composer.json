{
    "name": "acme/loyalty-redemption",
    "description": "Redeem loyalty points as a cart discount. Plugs into cart's AdjustmentRegistry; debits points on OrderPaid.",
    "type": "library",
    "license": "MIT",
    "version": "0.1.0",
    "repositories": [
        { "type": "path", "url": "../contracts", "options": { "symlink": true } },
        { "type": "path", "url": "../support",   "options": { "symlink": true } },
        { "type": "path", "url": "../starter",   "options": { "symlink": true } },
        { "type": "path", "url": "../auth",      "options": { "symlink": true } },
        { "type": "path", "url": "../rbac",      "options": { "symlink": true } },
        { "type": "path", "url": "../media",     "options": { "symlink": true } },
        { "type": "path", "url": "../cms-core",  "options": { "symlink": true } },
        { "type": "path", "url": "../catalog",   "options": { "symlink": true } },
        { "type": "path", "url": "../cart",      "options": { "symlink": true } },
        { "type": "path", "url": "../membership","options": { "symlink": true } },
        { "type": "path", "url": "../payments",  "options": { "symlink": true } },
        { "type": "path", "url": "../checkout",  "options": { "symlink": true } },
        { "type": "path", "url": "../commerce",  "options": { "symlink": true } }
    ],
    "require": {
        "php": "^8.3",
        "acme/starter": "*",
        "acme/cart": "*",
        "acme/checkout": "*",
        "acme/commerce": "*",
        "illuminate/events": "^12.0",
        "illuminate/http": "^12.0",
        "illuminate/routing": "^12.0",
        "illuminate/support": "^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Acme\\LoyaltyRedemption\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Acme\\LoyaltyRedemption\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": ["Acme\\LoyaltyRedemption\\LoyaltyRedemptionServiceProvider"]
        },
        "acme": {
            "module": {
                "key": "loyalty-redemption",
                "title": "Acme Loyalty · Redemption",
                "version": "0.1.0",
                "layer": 3,
                "depends": ["cart", "commerce", "checkout"]
            }
        }
    }
}
