{
    "name": "acme/platform",
    "description": "Acme modular Laravel platform — monorepo of acme/* packages.",
    "type": "project",
    "license": "MIT",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": "^8.3"
    },
    "require-dev": {
        "laravel/framework": "^12.0",
        "orchestra/testbench": "^10.0",
        "phpunit/phpunit": "^11.0",
        "laravel/pint": "^1.18",
        "phpstan/phpstan": "^2.0"
    },
    "repositories": [
        { "type": "path", "url": "packages/*", "options": { "symlink": true } }
    ],
    "scripts": {
        "test": "phpunit --colors=always",
        "lint": "pint --test",
        "fix": "pint",
        "stan": "phpstan analyse"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true
        }
    }
}
